# Cultini backend configuration.
# Two backends — see lib/core/constants/end_points.dart.
#
# 10.0.2.2 = the host machine as seen from the Android emulator.
# Use http://localhost for the iOS simulator / desktop, or your machine's
# LAN IP (e.g. http://192.168.1.20:3000) for a physical device.

# Node/Express auth backend (cultini-backend)
AUTH_BASE_URL=http://192.168.100.123:3000

# FastAPI Azetta RAG backend (cultini_AI)
AI_BASE_URL=http://127.0.0.1:8000
